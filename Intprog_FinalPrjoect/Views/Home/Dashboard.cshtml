@{
    ViewData["Title"] = "Dashboard";
    var userName = ViewBag.UserName as string ?? "Tenant";
    var balance = (decimal)(ViewBag.Balance ?? 0m);
}

@section Styles {
    <style>
        :root {
            --rust: #c0533a;
            --rust-light: #d9684e;
            --dark: #1a1410;
            --sand: #f4ede4;
            --white: #fdfaf7;
            --muted: #7a6a5e;
            --warm: #3d2b1f;
        }

        body {
            background: var(--sand);
        }

        .dash-header {
            background: var(--dark);
            color: #fff;
            padding: 40px 5vw 0;
        }

        .dash-header-inner {
            max-width: 1100px;
            margin: 0 auto;
        }

        .dash-greeting {
            font-size: .85rem;
            color: #8a7a6e;
            text-transform: uppercase;
            letter-spacing: .1em;
            margin-bottom: 6px;
        }

        .dash-name {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: clamp(1.8rem, 4vw, 2.8rem);
            font-weight: 800;
            color: #fff;
            margin-bottom: 32px;
        }

        .dash-tabs {
            display: flex;
            gap: 0;
            border-bottom: 2px solid rgba(255,255,255,.1);
        }

        .dash-tab {
            padding: 12px 24px;
            color: #8a7a6e;
            font-weight: 600;
            font-size: .88rem;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            margin-bottom: -2px;
            transition: color .2s, border-color .2s;
            text-decoration: none;
        }

            .dash-tab.active, .dash-tab:hover {
                color: var(--rust-light);
                border-bottom-color: var(--rust-light);
            }

        .dash-body {
            max-width: 1100px;
            margin: 0 auto;
            padding: 40px 5vw;
        }

        /* KPI CARDS */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px,1fr));
            gap: 20px;
            margin-bottom: 36px;
        }

        .kpi-card {
            background: var(--white);
            border-radius: 14px;
            padding: 28px 24px;
            border: 1px solid #e0d4c5;
            position: relative;
            overflow: hidden;
        }

        .kpi-accent {
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
        }

        .kpi-label {
            font-size: .78rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--muted);
            margin-bottom: 10px;
        }

        .kpi-value {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 800;
            color: var(--dark);
        }

        .kpi-sub {
            font-size: .8rem;
            color: var(--muted);
            margin-top: 4px;
        }

        /* LISTINGS TABLE */
        .section-card {
            background: var(--white);
            border-radius: 14px;
            border: 1px solid #e0d4c5;
            overflow: hidden;
            margin-bottom: 24px;
        }

        .section-card-header {
            padding: 20px 24px;
            border-bottom: 1px solid #e0d4c5;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .section-card-title {
            font-weight: 700;
            color: var(--dark);
            font-size: 1rem;
        }

        .badge-count {
            background: rgba(192,83,58,.12);
            color: var(--rust);
            font-size: .72rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 100px;
        }

        .listing-table {
            width: 100%;
            border-collapse: collapse;
        }

            .listing-table th {
                background: #f8f2ec;
                text-align: left;
                padding: 12px 20px;
                font-size: .78rem;
                font-weight: 700;
                color: var(--muted);
                text-transform: uppercase;
                letter-spacing: .07em;
                border-bottom: 1px solid #e0d4c5;
            }

            .listing-table td {
                padding: 16px 20px;
                border-bottom: 1px solid #f0e8e0;
                font-size: .9rem;
                color: var(--dark);
            }

            .listing-table tr:last-child td {
                border-bottom: none;
            }

            .listing-table tr:hover td {
                background: #fdf7f3;
            }

        .status-pill {
            display: inline-block;
            border-radius: 100px;
            padding: 3px 12px;
            font-size: .72rem;
            font-weight: 700;
        }

        .pill-available {
            background: #e6f4ea;
            color: #2e7d32;
        }

        .pill-rented {
            background: #fff3e0;
            color: #e65100;
        }

        .pill-pending {
            background: #e3f2fd;
            color: #1565c0;
        }

        .price-cell {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            color: var(--rust);
        }

        /* ADD LISTING FORM */
        .form-section {
            padding: 24px;
        }

        .form-label {
            font-weight: 600;
            font-size: .88rem;
            color: var(--dark);
            margin-bottom: 6px;
        }

        .form-control:focus {
            border-color: var(--rust);
            box-shadow: 0 0 0 3px rgba(192,83,58,.12);
        }

        .btn-rust {
            background: var(--rust);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 12px 32px;
            font-weight: 700;
            font-size: .95rem;
            cursor: pointer;
            transition: background .2s;
        }

            .btn-rust:hover {
                background: var(--rust-light);
            }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
}

<div class="dash-header">
    <div class="dash-header-inner">
        <div class="dash-greeting">Welcome back</div>
        <div class="dash-name">@userName 👋</div>
        <div class="dash-tabs">
            <a class="dash-tab active" href="#">Overview</a>
            <a class="dash-tab" href="#">My Rentals</a>
            <a class="dash-tab" href="#">Saved</a>
            <a class="dash-tab" href="#">Settings</a>
        </div>
    </div>
</div>

<div class="dash-body">

    <!-- KPI ROW -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-accent" style="background:var(--rust)"></div>
            <div class="kpi-label">Wallet Balance</div>
            <div class="kpi-value">₱@balance.ToString("N2")</div>
            <div class="kpi-sub">Philippine Peso</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-accent" style="background:#2e7d32"></div>
            <div class="kpi-label">Active Listings</div>
            <div class="kpi-value">2,418</div>
            <div class="kpi-sub">Across 12 cities</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-accent" style="background:#1565c0"></div>
            <div class="kpi-label">Saved Properties</div>
            <div class="kpi-value">0</div>
            <div class="kpi-sub">Start browsing!</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-accent" style="background:#7b1fa2"></div>
            <div class="kpi-label">Inquiries Sent</div>
            <div class="kpi-value">0</div>
            <div class="kpi-sub">Contact a landlord</div>
        </div>
    </div>

    <!-- FEATURED LISTINGS TABLE -->
    <div class="section-card">
        <div class="section-card-header">
            <div class="section-card-title">Featured Rental Listings</div>
            <span class="badge-count">6 listings</span>
        </div>
        <table class="listing-table">
            <thead>
                <tr>
                    <th>Property</th>
                    <th>Location</th>
                    <th>Type</th>
                    <th>Monthly Rent</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Modern Studio Unit</strong><br><small style="color:var(--muted)">Fully furnished, 28 sqm</small></td>
                    <td>Cebu IT Park, Cebu City</td>
                    <td>Studio</td>
                    <td class="price-cell">₱12,000</td>
                    <td><span class="status-pill pill-available">Available</span></td>
                </tr>
                <tr>
                    <td><strong>3BR House with Garden</strong><br><small style="color:var(--muted)">Corner lot, 120 sqm</small></td>
                    <td>Mandaue City, Cebu</td>
                    <td>House &amp; Lot</td>
                    <td class="price-cell">₱28,500</td>
                    <td><span class="status-pill pill-available">Available</span></td>
                </tr>
                <tr>
                    <td><strong>1BR Condo with Balcony</strong><br><small style="color:var(--muted)">High floor, city view</small></td>
                    <td>Makati City, Metro Manila</td>
                    <td>Condo</td>
                    <td class="price-cell">₱22,000</td>
                    <td><span class="status-pill pill-rented">Rented</span></td>
                </tr>
                <tr>
                    <td><strong>Boarding Room</strong><br><small style="color:var(--muted)">Shared kitchen, bills incl.</small></td>
                    <td>Lahug, Cebu City</td>
                    <td>Bedspace</td>
                    <td class="price-cell">₱4,500</td>
                    <td><span class="status-pill pill-available">Available</span></td>
                </tr>
                <tr>
                    <td><strong>2BR Apartment</strong><br><small style="color:var(--muted)">Semi-furnished, parking</small></td>
                    <td>Talisay City, Cebu</td>
                    <td>Apartment</td>
                    <td class="price-cell">₱16,000</td>
                    <td><span class="status-pill pill-pending">Pending</span></td>
                </tr>
                <tr>
                    <td><strong>Commercial Space</strong><br><small style="color:var(--muted)">Ground floor, high foot traffic</small></td>
                    <td>Colon St., Cebu City</td>
                    <td>Commercial</td>
                    <td class="price-cell">₱35,000</td>
                    <td><span class="status-pill pill-available">Available</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- POST A LISTING -->
    <div class="section-card">
        <div class="section-card-header">
            <div class="section-card-title">Post a New Listing</div>
        </div>
        <div class="form-section">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Property Title</label>
                    <input type="text" class="form-control" placeholder="e.g. Cozy Studio in Cebu IT Park" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <select class="form-select">
                        <option>Studio</option>
                        <option>1BR Apartment</option>
                        <option>2BR Apartment</option>
                        <option>House &amp; Lot</option>
                        <option>Condo</option>
                        <option>Bedspace</option>
                        <option>Commercial</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Monthly Rent (₱)</label>
                    <input type="number" class="form-control" placeholder="0.00" min="0" />
                </div>
                <div class="col-md-8">
                    <label class="form-label">Location / Address</label>
                    <input type="text" class="form-control" placeholder="Barangay, City, Province" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Contact Number</label>
                    <input type="tel" class="form-control" placeholder="09XXXXXXXXX" />
                </div>
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="3" placeholder="Describe your property — size, inclusions, nearby landmarks..."></textarea>
                </div>
                <div class="col-12">
                    <button class="btn-rust">Post Listing</button>
                </div>
            </div>
        </div>
    </div>

</div>
